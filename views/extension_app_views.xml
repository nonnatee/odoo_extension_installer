<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="view_extension_app_search" model="ir.ui.view">
        <field name="name">extension.app.search</field>
        <field name="model">extension.app</field>
        <field name="arch" type="xml">
            <search string="Search App Store">
                <field name="name" string="Module Title/Summary" filter_domain="['|', '|', ('name', 'ilike', self), ('tech_name', 'ilike', self), ('summary', 'ilike', self)]"/>
                <field name="tech_name" string="Technical Name"/>
                <field name="author" string="Author"/>
            </search>
        </field>
    </record>

    <!-- Tree/List View -->
    <record id="view_extension_app_tree" model="ir.ui.view">
        <field name="name">extension.app.tree</field>
        <field name="model">extension.app</field>
        <field name="arch" type="xml">
            <list string="App Store" create="false" edit="false" delete="false">
                <field name="name"/>
                <field name="tech_name"/>
                <field name="author"/>
                <field name="downloads_str"/>
                <field name="price"/>
                <button name="action_install_app" string="Install" type="object" class="btn-primary btn-sm"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_extension_app_kanban" model="ir.ui.view">
        <field name="name">extension.app.kanban</field>
        <field name="model">extension.app</field>
        <field name="arch" type="xml">
            <kanban create="false" edit="false" delete="false" records_draggable="false" class="o_kanban_mobile">
                <field name="name"/>
                <field name="tech_name"/>
                <field name="summary"/>
                <field name="author"/>
                <field name="icon_url"/>
                <field name="downloads_str"/>
                <field name="price"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click d-flex flex-column justify-content-between p-3 border rounded shadow-sm bg-white" style="height: 180px; transition: transform 0.2s, box-shadow 0.2s; min-width: 250px;">
                            <div class="d-flex align-items-start gap-3">
                                <!-- App Icon -->
                                <div class="flex-shrink-0" style="width: 60px; height: 60px;">
                                    <t t-if="record.icon_url.raw_value">
                                        <img t-att-src="record.icon_url.raw_value" alt="App Icon" class="w-100 h-100 rounded-3 border bg-light object-fit-cover" style="object-fit: cover; max-height: 60px; max-width: 60px;"/>
                                    </t>
                                    <t t-else="">
                                        <div class="w-100 h-100 bg-secondary rounded-3 d-flex align-items-center justify-content-center text-white font-weight-bold" style="font-size: 24px;">
                                            <i class="fa fa-cube"/>
                                        </div>
                                    </t>
                                </div>
                                <!-- App Info -->
                                <div class="flex-grow-1 overflow-hidden" style="max-height: 90px;">
                                    <div class="text-truncate" style="font-size: 1.05rem; font-weight: 700; color: #1f2937;" t-att-title="record.name.raw_value">
                                        <field name="name"/>
                                    </div>
                                    <div class="mb-1 text-muted" style="font-size: 0.8rem; font-family: monospace;">
                                        <code><field name="tech_name"/></code>
                                    </div>
                                    <div class="text-muted text-break-line" style="font-size: 0.85rem; line-height: 1.25; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;" t-att-title="record.summary.raw_value">
                                        <field name="summary"/>
                                    </div>
                                </div>
                            </div>
                            <!-- Bottom Footer -->
                            <div class="d-flex align-items-center justify-content-between pt-2 border-top mt-auto" style="border-color: #f3f4f6 !important;">
                                <div class="text-muted" style="font-size: 0.78rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 130px;" t-att-title="record.author.raw_value">
                                    By <field name="author"/>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <t t-if="record.downloads_str.raw_value">
                                        <span class="badge rounded-pill bg-light text-dark border px-2 py-1" style="font-size: 0.72rem; font-weight: 500;" t-att-title="'Downloads: ' + record.downloads_str.raw_value">
                                            <i class="fa fa-download text-muted me-1"/> <t t-esc="record.downloads_str.raw_value"/>
                                        </span>
                                    </t>
                                    <button name="action_install_app" type="object" class="btn btn-primary btn-sm px-3 py-1 font-weight-bold" style="border-radius: 6px; font-size: 0.82rem;">
                                        Install
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action Record -->
    <record id="action_extension_app_browser" model="ir.actions.act_window">
        <field name="name">App Store Browser</field>
        <field name="res_model">extension.app</field>
        <field name="view_mode">kanban,list</field>
        <field name="search_view_id" ref="view_extension_app_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Searching Odoo Apps Store...
            </p>
            <p>
                Ensure internet connectivity is active. If the list is empty, try typing a search keyword in the search box above.
            </p>
        </field>
    </record>
</odoo>
