<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_extension_install_wizard_form" model="ir.ui.view">
        <field name="name">extension.install.wizard.form</field>
        <field name="model">extension.install.wizard</field>
        <field name="arch" type="xml">
            <form string="Install Third-Party Module">
                <field name="state" invisible="1"/>
                
                <!-- STATE: INIT -->
                <div invisible="state != 'init'">
                    <group string="Source Configuration">
                        <field name="source_type" widget="radio" options="{'horizontal': true}"/>
                        <field name="github_url" invisible="source_type != 'github'" required="source_type == 'github'"/>
                        <field name="github_branch" invisible="source_type != 'github'"/>
                        <field name="zip_file" filename="zip_filename" invisible="source_type != 'zip'" required="source_type == 'zip'"/>
                        <field name="zip_filename" invisible="1"/>
                    </group>
                    <group string="Installation Options">
                        <field name="target_path"/>
                    </group>
                </div>

                <!-- STATE: REVIEW -->
                <div invisible="state != 'review'">
                    <div class="alert alert-info" role="alert">
                        Please review the module(s) found in the archive and check for any missing dependencies before confirming the installation.
                    </div>
                    <field name="review_message" widget="html"/>
                    <group string="Destination">
                        <field name="target_path" readonly="1"/>
                    </group>
                </div>

                <!-- STATE: DONE -->
                <div invisible="state != 'done'">
                    <div class="alert alert-success text-center" role="alert" style="font-size: 1.2rem;">
                        <strong>Success!</strong> The modules have been extracted and registered.
                    </div>
                    <group string="Installed Modules">
                        <field name="installed_modules_log" readonly="1" class="text-success"/>
                    </group>
                    <div invisible="not restart_pending" class="alert alert-warning" role="alert">
                        <h4 class="alert-heading">Restart Required</h4>
                        <p>New Python files have been added to the addons path. You must restart the Odoo server to load them.</p>
                        <hr/>
                        <button name="action_restart_server" type="object" string="Restart Odoo Server Now" class="btn btn-danger"/>
                    </div>
                </div>

                <!-- FOOTERS -->
                <footer>
                    <div invisible="state != 'init'">
                        <button name="action_download_and_review" string="Review &amp; Verify" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </div>
                    <div invisible="state != 'review'">
                        <button name="action_install_confirm" string="Extract &amp; Install" type="object" class="btn-primary"/>
                        <button name="action_back" string="Back" type="object" class="btn-secondary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </div>
                    <div invisible="state != 'done'">
                        <button string="Close" class="btn-primary" special="cancel"/>
                    </div>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_extension_install_wizard" model="ir.actions.act_window">
        <field name="name">Install Extension</field>
        <field name="res_model">extension.install.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
